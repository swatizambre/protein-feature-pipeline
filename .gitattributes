# Normalize text files to LF in the repo (avoids Windows CRLF noise in PRs)
* text=auto eol=lf

*.py   text eol=lf
*.md   text eol=lf
*.toml text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.txt  text eol=lf
*.sh   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf

# Keep binary assets untouched
*.png  binary
*.npz  binary
*.pdb  binary
*.pdf  binary
